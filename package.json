{
  "name": "proofdock",
  "version": "0.1.0",
  "description": "Static proof bundle generator for agent-produced commits, checks, screenshots, and notes.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "proofdock": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "smoke": "npm run build && node scripts/smoke.mjs"
  },
  "keywords": [
    "agents",
    "proof",
    "review",
    "static-site",
    "cli"
  ],
  "author": "StackForge User",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
