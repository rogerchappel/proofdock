{
  "name": "proofdock",
  "version": "0.1.0",
  "description": "Static proof bundle generator for agent-produced commits, checks, screenshots, and notes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "proofdock": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke && npm pack --dry-run"
  },
  "keywords": [
    "agents",
    "proof",
    "review",
    "static-site",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/proofdock.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/proofdock/issues"
  },
  "homepage": "https://github.com/rogerchappel/proofdock#readme",
  "packageManager": "npm@11.11.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
